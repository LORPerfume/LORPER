<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOR' PERFUME</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
:root{
  --gold:#d4af37;
  --black:#0d0d0d;
  --gray:#777;
  --bg:#f7f7f7;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Inter, sans-serif;
}

body{
  background:var(--bg);
  color:#222;
}

/* NAVBAR */
nav{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  background:rgba(0,0,0,.85);
  backdrop-filter: blur(10px);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px 40px;
  z-index:1000;
}

nav h1{
  font-family:'Playfair Display', serif;
  color:var(--gold);
  letter-spacing:2px;
}

nav a{
  color:white;
  margin-left:20px;
  text-decoration:none;
  font-size:14px;
  transition:.3s;
}

nav a:hover{
  color:var(--gold);
}

/* HERO */
.hero{
  height:100vh;
  background:url('https://images.unsplash.com/photo-1523293182086-7651a899d37f?auto=format&fit=crop&w=1600&q=80') center/cover;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  position:relative;
}

.hero::after{
  content:'';
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.6);
}

.hero-content{
  position:relative;
  color:white;
  max-width:700px;
}

.hero h2{
  font-size:52px;
  font-family:'Playfair Display', serif;
}

.hero p{
  margin-top:15px;
  color:#ddd;
}

.btn{
  display:inline-block;
  margin-top:25px;
  padding:14px 30px;
  background:var(--gold);
  color:black;
  font-weight:bold;
  text-decoration:none;
  border-radius:30px;
  transition:.3s;
}

.btn:hover{
  transform:scale(1.05);
}

/* SECTIONS */
.section{
  padding:90px 20px;
  max-width:1200px;
  margin:auto;
}

.title{
  text-align:center;
  font-size:36px;
  font-family:'Playfair Display', serif;
}

.subtitle{
  text-align:center;
  color:var(--gray);
  margin-top:10px;
  max-width:700px;
  margin-left:auto;
  margin-right:auto;
}

/* PRODUCTS */
.grid{
  margin-top:50px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:25px;
}

.card{
  background:white;
  border-radius:15px;
  overflow:hidden;
  box-shadow:0 10px 25px rgba(0,0,0,.08);
  transition:.4s;
}

.card:hover{
  transform:translateY(-10px);
}

.card img{
  width:100%;
  height:220px;
  object-fit:cover;
}

.card-body{
  padding:20px;
  text-align:center;
}

.card h3{
  font-family:'Playfair Display', serif;
  margin-bottom:10px;
}

.price{
  margin-top:10px;
  color:var(--gold);
  font-size:20px;
  font-weight:bold;
}

/* FEATURES */
.features{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
  margin-top:50px;
}

.feature{
  background:white;
  padding:25px;
  border-radius:12px;
  text-align:center;
  box-shadow:0 5px 20px rgba(0,0,0,.05);
}

/* CONTACT */
.contact{
  background:#111;
  color:white;
  text-align:center;
  padding:70px 20px;
}

.contact p{
  color:#ccc;
}

/* FOOTER */
footer{
  background:black;
  color:#aaa;
  text-align:center;
  padding:20px;
  font-size:13px;
}

/* WHATSAPP FLOAT */
.whatsapp{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  color:white;
  padding:15px 18px;
  border-radius:50px;
  text-decoration:none;
  font-weight:bold;
  box-shadow:0 10px 20px rgba(0,0,0,.2);
}

/* RESPONSIVE */
@media(max-width:768px){
  nav{
    padding:15px 20px;
  }
  .hero h2{
    font-size:36px;
  }
}
</style>

</head>

<body>

<nav>
  <h1>LOR' PERFUME</h1>
  <div>
    <a href="#products">Products</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-content">
    <h2>Luxury That Defines You</h2>
    <p>Discover exclusive fragrances crafted for elegance, confidence, and timeless identity.</p>
    <a class="btn" href="https://wa.me/962787727783">Shop Now</a>
  </div>
</section>

<section class="section" id="products">
  <h2 class="title">Featured Collection</h2>
  <p class="subtitle">Premium perfumes inspired by luxury, crafted to last all day.</p>

  <div class="grid">

    <div class="card">
      <img src="https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&w=600&q=80">
      <div class="card-body">
        <h3>Royal Oud</h3>
        <p>Deep oriental oud with luxury finish.</p>
        <div class="price">25 JOD</div>
      </div>
    </div>

    <div class="card">
      <img src="https://images.unsplash.com/photo-1594035910387-fea47794261f?auto=format&fit=crop&w=600&q=80">
      <div class="card-body">
        <h3>Golden Essence</h3>
        <p>Floral amber blend with elegant touch.</p>
        <div class="price">22 JOD</div>
      </div>
    </div>

    <div class="card">
      <img src="https://images.unsplash.com/photo-1523293182086-7651a899d37f?auto=format&fit=crop&w=600&q=80">
      <div class="card-body">
        <h3>Midnight Touch</h3>
        <p>Mysterious evening fragrance.</p>
        <div class="price">28 JOD</div>
      </div>
    </div>

  </div>
</section>

<section class="section" id="about">
  <h2 class="title">About Us</h2>
  <p class="subtitle">
    LOR' PERFUME represents elegance and identity. Every scent tells a story,
    designed to leave a lasting impression wherever you go.
  </p>

  <div class="features">
    <div class="feature">
      <h3>Premium Quality</h3>
      <p>High-end fragrance ingredients.</p>
    </div>

    <div class="feature">
      <h3>Long Lasting</h3>
      <p>Scent that stays all day.</p>
    </div>

    <div class="feature">
      <h3>Luxury Feel</h3>
      <p>Elegant experience at affordable price.</p>
    </div>
  </div>
</section>

<section class="contact" id="contact">
  <h2>Contact Us</h2>
  <p>WhatsApp: +962 78 772 7783</p>
  <a class="btn" href="https://wa.me/962787727783">Chat Now</a>
</section>

<footer>
  © 2026 LOR' PERFUME — All Rights Reserved
</footer>

<a class="whatsapp" href="https://wa.me/962787727783">WhatsApp</a>

</body>
</html>
